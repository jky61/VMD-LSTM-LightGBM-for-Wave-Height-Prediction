if __name__ == "__main__":
    overall_start_time = time.time()
    cfg = Config()

    try:
        # Set seeds for reproducibility
        torch.manual_seed(42)
        if torch.cuda.is_available():
            torch.cuda.manual_seed(42)
        np.random.seed(42)

        target_column = cfg.TARGET_COLUMN
        print(f"\n{'=' * 25} Initialization {'=' * 25}")
        print(f"Target: {target_column} | Horizon: t+{cfg.FORECAST_HORIZON} | Device: {cfg.DEVICE}")

        # 1. Load Data
        all_columns_to_load = [cfg.TARGET_COLUMN] + cfg.EXTERNAL_FEATURES
        df_clean = load_and_clean_data(cfg.FILE_PATH, all_columns_to_load, cfg.TARGET_COLUMN, cfg.TIME_COLUMN)

        if not df_clean.empty:
            # 2. VMD Decomposition
            df_imfs = decompose_signal(df_clean, target_column, cfg)
            df_full = pd.concat([df_clean, df_imfs], axis=1)

            component_cols = df_imfs.columns.tolist()
            cols_for_lgbm_features = cfg.LOW_FREQ_COMPONENTS + cfg.EXTERNAL_FEATURES
            
            # 3. Feature Engineering for Tree Models
            df_featured_lgbm = create_features_for_lgbm(df_full, cols_for_lgbm_features, cfg)

            all_predictions = {}
            final_test_size = 0

            # Alignment logic due to rolling windows dropping rows
            offset = len(df_full) - len(df_featured_lgbm)
            train_size_offset = int(len(df_featured_lgbm) * cfg.TRAIN_SIZE_RATIO)

            train_df_orig = df_full.iloc[offset: offset + train_size_offset]
            test_df_orig = df_full.iloc[offset + train_size_offset:]

            train_df_lgbm = df_featured_lgbm.iloc[:train_size_offset]
            test_df_lgbm = df_featured_lgbm.iloc[train_size_offset:]

            prediction_offset = cfg.LOOK_BACK - 1

            # 4. Sub-model Training & Prediction
            for component in component_cols:
                if component in cfg.LOW_FREQ_COMPONENTS:
                    # Target assignment: LightGBM
                    targets_to_exclude = [target_column] + component_cols
                    feature_cols = [col for col in df_featured_lgbm.columns if
                                    col not in targets_to_exclude and col != 'ds' and col != cfg.TIME_COLUMN]

                    predictions = train_and_predict_lightgbm(train_df_lgbm, test_df_lgbm, component, feature_cols, cfg)
                    aligned_lgbm_predictions = predictions[prediction_offset:]
                    all_predictions[component] = aligned_lgbm_predictions

                else:  
                    # Target assignment: LSTM
                    predictions, test_size = train_and_predict_lstm(train_df_orig, test_df_orig, component,
                                                                    cfg.EXTERNAL_FEATURES, cfg)
                    all_predictions[component] = predictions

                    if final_test_size == 0 and test_size > 0:
                        final_test_size = test_size

            # 5. Reconstruction & Evaluation
            if final_test_size > 0:
                valid_preds = []
                for comp_name, preds in all_predictions.items():
                    if len(preds) >= final_test_size:
                        valid_preds.append(preds[:final_test_size])
                    else:
                        padded_preds = np.zeros(final_test_size)
                        padded_preds[:len(preds)] = preds
                        valid_preds.append(padded_preds)

                final_predictions = np.sum(valid_preds, axis=0)

                # Extract aligned real values
                real_values_start_index_in_full = test_df_orig.index[0] + cfg.LOOK_BACK + cfg.FORECAST_HORIZON - 1
                real_values_end_index_in_full = real_values_start_index_in_full + final_test_size
                real_values = df_full[target_column].iloc[real_values_start_index_in_full:real_values_end_index_in_full]

                if len(final_predictions) != len(real_values):
                    min_len = min(len(final_predictions), len(real_values))
                    final_predictions = final_predictions[:min_len]
                    real_values = real_values.iloc[:min_len]

                # Output Metrics
                evaluate_metrics(final_predictions, real_values, target_column)

            else:
                print(f"Error: Failed to generate valid test predictions.")

    except NotImplementedError as e:
        print(f"\n[Notice]: {e}")
    except Exception as e:
        print(f"\n{'=' * 25} An unexpected error occurred {'=' * 25}")
        print(f"Error Type: {type(e).__name__}\nError Message: {e}")
        traceback.print_exc()

    print(f"\n--- Total execution time: {((time.time() - overall_start_time) / 60):.2f} minutes ---")
