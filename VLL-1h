class PyTorchLSTM(nn.Module):
    def __init__(self, input_dim, hidden_dim, output_dim=1, dropout=0.2):
        super(PyTorchLSTM, self).__init__()
        self.lstm1 = nn.LSTM(input_dim, hidden_dim, batch_first=True)
        self.dropout1 = nn.Dropout(dropout)
        self.lstm2 = nn.LSTM(hidden_dim, hidden_dim // 2, batch_first=True)
        self.dropout2 = nn.Dropout(dropout)
        self.fc = nn.Linear(hidden_dim // 2, output_dim)

    def forward(self, x):
        out, _ = self.lstm1(x)
        out = self.dropout1(out)
        out, _ = self.lstm2(out)
        out = out[:, -1, :]
        out = self.dropout2(out)
        out = self.fc(out)
        return out


class EarlyStoppingPyTorch:
    """Early stops the training if validation loss doesn't improve after a given patience."""
    def __init__(self, patience=10, verbose=False, delta=0):
        self.patience = patience
        self.verbose = verbose
        self.counter = 0
        self.best_score = None
        self.early_stop = False
        self.val_loss_min = np.Inf
        self.delta = delta
        self.best_state_dict = None

    def __call__(self, val_loss, model):
        score = -val_loss
        if self.best_score is None:
            self.best_score = score
            self.save_checkpoint(val_loss, model)
        elif score < self.best_score + self.delta:
            self.counter += 1
            if self.counter >= self.patience:
                self.early_stop = True
        else:
            self.best_score = score
            self.save_checkpoint(val_loss, model)
            self.counter = 0

    def save_checkpoint(self, val_loss, model):
        self.val_loss_min = val_loss
        self.best_state_dict = model.state_dict()

    def load_best_weights(self, model):
        if self.best_state_dict is not None:
            model.load_state_dict(self.best_state_dict)


def train_and_predict_lstm(df_train, df_test, component, external_features, config):
    """Train LSTM on specific IMF and predict the test set."""
    lstm_cols = external_features + [component]
    num_features = len(lstm_cols)

    train_data = df_train[lstm_cols].values
    test_data = df_test[lstm_cols].values

    scaler = MinMaxScaler(feature_range=(0, 1))
    scaled_train_data = scaler.fit_transform(train_data)
    scaled_test_data = scaler.transform(test_data)

    target_scaler = MinMaxScaler(feature_range=(0, 1))
    target_scaler.fit(df_train[[component]])

    X_train, y_train = create_lstm_dataset(scaled_train_data, config.LOOK_BACK, config.FORECAST_HORIZON)
    X_test, y_test_raw = create_lstm_dataset(scaled_test_data, config.LOOK_BACK, config.FORECAST_HORIZON)

    if len(X_train) == 0 or len(X_test) == 0:
        return np.array([]), 0

    X_train_tensor = torch.FloatTensor(X_train).to(config.DEVICE)
    y_train_tensor = torch.FloatTensor(y_train).view(-1, 1).to(config.DEVICE)
    X_test_tensor = torch.FloatTensor(X_test).to(config.DEVICE)
    y_test_tensor = torch.FloatTensor(y_test_raw).view(-1, 1).to(config.DEVICE)

    train_dataset = TensorDataset(X_train_tensor, y_train_tensor)
    val_dataset = TensorDataset(X_test_tensor, y_test_tensor)

    train_loader = DataLoader(train_dataset, batch_size=config.BATCH_SIZE, shuffle=False)
    val_loader = DataLoader(val_dataset, batch_size=config.BATCH_SIZE, shuffle=False)

    model = PyTorchLSTM(input_dim=num_features, hidden_dim=config.LSTM_UNITS).to(config.DEVICE)
    criterion = nn.MSELoss()
    optimizer = optim.Adam(model.parameters(), lr=0.001)

    early_stopping = EarlyStoppingPyTorch(patience=10, verbose=False)

    for epoch in range(config.EPOCHS):
        model.train()
        for X_batch, y_batch in train_loader:
            optimizer.zero_grad()
            output = model(X_batch)
            loss = criterion(output, y_batch)
            loss.backward()
            optimizer.step()

        model.eval()
        val_loss = 0.0
        with torch.no_grad():
            for X_val, y_val in val_loader:
                output = model(X_val)
                loss = criterion(output, y_val)
                val_loss += loss.item() * X_val.size(0)

        val_loss /= len(val_loader.dataset)
        early_stopping(val_loss, model)
        if early_stopping.early_stop:
            break

    early_stopping.load_best_weights(model)

    model.eval()
    with torch.no_grad():
        predicted_scaled = model(X_test_tensor).cpu().numpy()

    predictions_inversed = target_scaler.inverse_transform(predicted_scaled)
    return predictions_inversed.ravel(), len(y_test_raw)


def train_and_predict_lightgbm(df_train, df_test, component, feature_cols, config):
    """Train LightGBM on specific IMF and predict the test set."""
    X_train_full = df_train[feature_cols]
    X_test_full = df_test[feature_cols]

    y_shift = -config.FORECAST_HORIZON
    y_train_shifted = df_train[component].shift(y_shift)
    y_test_shifted = df_test[component].shift(y_shift)

    train_mask = y_train_shifted.notna()
    X_train, y_train = X_train_full[train_mask], y_train_shifted[train_mask]

    test_mask = y_test_shifted.notna()
    X_test, y_test = X_test_full[test_mask], y_test_shifted[test_mask]

    model = lgb.LGBMRegressor(**config.LGB_PARAMS_LOW_FREQ)
    model.fit(X_train, y_train, eval_set=[(X_test, y_test)], eval_metric='rmse',
              callbacks=[lgb.early_stopping(50, verbose=False)])

    return model.predict(X_test_full)


def evaluate_metrics(predictions, real_values, target_column):
    """
    Calculate and print metrics. 
    [Plotting and detailed CSV saving mechanisms have been removed for public release].
    """
    predictions = np.array(predictions)
    real_values = np.array(real_values) if not isinstance(real_values, pd.Series) else real_values.values

    rmse = np.sqrt(mean_squared_error(real_values, predictions))
    mae = mean_absolute_error(real_values, predictions)
    r2 = r2_score(real_values, predictions)

    print(f"\n--- Evaluation Metrics for {target_column} ---")
    print(f'RMSE: {rmse:.4f}')
    print(f'MAE:  {mae:.4f}')
    print(f'R²:   {r2:.4f}')
    print("---------------------------------------------")


